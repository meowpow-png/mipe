set shell := ["bash", "-eu", "-o", "pipefail", "-c"]

import "just/agent.just"
import "just/docker.just"
import "just/test.just"

# List available recipes
default:
    @just --list

# Build bootstrap binary
build:
    @mkdir -p build
    @go build -o build/bin/mipe ./cmd/mipe

# Clean build artifacts
clean:
    @rm -rf build

# Run Mipe locally
[arg("args", help="Arguments passed to Mipe")]
mipe *args: build
    @mkdir -p .mipe/local-home .mipe/agent-home
    @RUNTIME_HOME="$PWD/docker/runtime/base" \
     USER_HOME="$PWD/.mipe/local-home" \
     AGENT_HOME="$PWD/.mipe/agent-home" \
     WORKSPACE="$PWD" \
     LOCAL_UID="$(id -u)" \
     LOCAL_GID="$(id -g)" \
     ./build/bin/mipe --config docker/runtime/base/config/config.json {{args}}

# Run Mipe in runtime container
[arg("args", help="Arguments passed to Mipe")]
mipe-docker *args:
    just compose run --rm mipe mipe {{args}}
