set shell := ["bash", "-eu", "-o", "pipefail", "-c"]

# List available recipes
default:
    @just --list

# Build bootstrap binary
build:
    @mkdir -p build
    @go build -o build/bin/mipe ./cmd/mipe

# Build production binary
build-production:
    @mkdir -p build
    @go build \
        -trimpath \
        -ldflags="-s -w -buildid=" \
        -o build/bin/mipe \
        ./cmd/mipe

# Build docker images
[arg("targets", help="Bake targets to build")]
build-images *targets='default':
    @docker buildx bake {{targets}}

# Clean build artifacts
clean:
    @rm -rf build

# Run base docker compose stack
[arg("args", help="Arguments passed to docker compose")]
compose *args:
    @docker compose {{args}}

# Run test docker compose stack
[arg("args", help="Arguments passed to docker compose")]
compose-test *args:
    @just compose -f compose.test.yml {{args}}

# Run Go tests
[arg("args", help="Arguments passed to go test")]
test *args:
    @go test {{args}} ./...

# Run Go tests with coverage
[arg("args", help="Arguments passed to go test")]
test-coverage *args:
    @mkdir -p build/report
    @go test -coverprofile=build/report/coverage.out {{args}} ./...
    @go tool cover -func=build/report/coverage.out

# Run integration test with docker
[arg("args", help="Arguments passed to docker compose")]
integration-test *args:
    @just compose-test run --rm --build runtime-test {{args}}

# Run Codex in a disposable container
[arg("args", help="Arguments passed to container")]
codex-run *args:
    @just compose run --rm codex {{args}}

# Start a Bash shell in Codex container
codex-shell:
    @just compose run --rm --entrypoint bash codex

# Run Claude in a disposable container
[arg("args", help="Arguments passed to container")]
claude-run *args:
    @just compose run --rm claude {{args}}

# Start a Bash shell in Claude container
claude-shell:
    @just compose run --rm --entrypoint bash claude
