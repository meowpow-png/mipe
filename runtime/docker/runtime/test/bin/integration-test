#!/usr/bin/env bash
set -euo pipefail

assert_file_exists() {
    local path="$1"
    local message="$2"

    if [[ -f "$path" ]]; then
        echo "✓ $message"
        return
    fi
    echo "✗ $message"
    echo "  Expected file: $path"
    echo "  Actual: file does not exist"
    exit 1
}

echo "Running integration tests:"

assert_file_exists /workspace/.test "Project dependencies initialized"
assert_file_exists /home/dev/.mipe-agent/config.json "Runtime config copied to agent home"

echo "✓ Integration tests passed"
